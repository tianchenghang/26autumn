{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": [
      "node",
      "vite/client"
    ],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@swifty-docs/generated": [
        "./.swifty-docs/generated/index.js"
      ]
    }
  },
  "include": [
    "app",
    "swifty-docs.config.ts",
    "vite.config.ts"
  ]
}
