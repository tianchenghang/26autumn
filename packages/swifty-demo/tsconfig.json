{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "sourceMap": true,
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "noPropertyAccessFromIndexSignature": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    // NOTE: Do NOT put `"./@mf-types"` in `types` here.
    // Instead, @mf-types/index.d.ts is loaded via a triple-slash reference in
    // src/vite-env.d.ts (relative to the source file, not the tsconfig).
    "paths": {
      "swifty_devtool/*": ["./@mf-types/swifty_devtool/*"]
    }
  }
}
