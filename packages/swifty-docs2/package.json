{
  "name": "@swifty.js/docs2",
  "version": "0.1.0",
  "description": "jQuery documentation site generator with a markdown-it pipeline",
  "keywords": [
    "@swifty.js",
    "markdown",
    "documentation",
    "docs",
    "jquery"
  ],
  "license": "MIT",
  "author": "https://github.com/hangtiancheng",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./compiler": {
      "import": {
        "types": "./dist/compiler.d.ts",
        "default": "./dist/compiler.js"
      },
      "require": {
        "types": "./dist/compiler.d.ts",
        "default": "./dist/compiler.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./theme": {
      "import": {
        "types": "./dist/theme/index.d.ts",
        "default": "./dist/theme.js"
      },
      "require": {
        "types": "./dist/theme/index.d.ts",
        "default": "./dist/theme.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts"
      },
      "require": {
        "types": "./dist/client.d.ts"
      }
    }
  },
  "scripts": {
    "prepublish": "pnpm build",
    "git:pull": "node ./pull.js",
    "build": "vite build --mode lib",
    "build:docs": "vite build --mode docs",
    "build:watch": "vite build --mode lib --watch",
    "dev": "vite --mode docs",
    "preview": "vite preview --mode docs",
    "format": "prettier -w ./ --experimental-cli",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pwa": "pnpm dlx @vite-pwa/assets-generator --preset minimal public/favicon.svg"
  },
  "dependencies": {
    "@docsearch/css": "^4.6.3",
    "@docsearch/js": "^4.6.3",
    "clsx": "^2.1.0",
    "ejs": "^3.1.10",
    "jquery": "^4.0.0",
    "js-yaml": "^5.2.0",
    "lucide-static": "^0.525.0",
    "markdown-it": "^14.2.0",
    "markdown-it-container": "^4.0.0",
    "minisearch": "^7.2.0",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/ejs": "^3.1.5",
    "@types/jquery": "^3.5.32",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "jquery": "^4.0.0",
    "tailwindcss": "^4.0.0"
  },
  "lint-staged": {
    "*.{json,jsonc,js,cjs,mjs,ts,cts,mts,html,css,md}": [
      "pnpm format"
    ]
  },
  "packageManager": "pnpm@10.33.1"
}
