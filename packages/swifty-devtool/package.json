{
  "name": "@swifty.js/devtool",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "rm -rf ./dist && vite",
    "dev:webpack": "rm -rf ./dist && webpack serve --mode development",
    "dev:rsbuild": "rm -rf ./dist && rsbuild dev",
    "build": "vite build",
    "build:webpack": "tsc --noEmit && webpack --mode production",
    "build:rsbuild": "rsbuild build",
    "preview": "vite preview",
    "preview:webpack": "webpack serve --mode production",
    "preview:rsbuild": "rsbuild preview"
  },
  "dependencies": {
    "@swifty.js/mvc": "workspace:^",
    "@module-federation/runtime": "^2.6.0",
    "@sentry/react": "^10.62.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-virtual": "^3.14.4",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.16.12",
    "@rsbuild/core": "^2.1.1",
    "@rsbuild/plugin-react": "^2.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.3.2",
    "ts-loader": "^9.6.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.1",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "webpack-dev-server": "^5.2.5"
  }
