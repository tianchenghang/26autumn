graph TB
    subgraph Client["Client Process"]
        APP["Application"]
        G["Group (namespace)"]
        SF["SingleFlightGroup"]
        CACHE["Cache Wrapper"]
        LRU["lruStore (bucket-sharded)"]
        subgraph Buckets["Buckets"]
            B0["Bucket 0: L1 + L2"]
            B1["Bucket 1: L1 + L2"]
            BN["Bucket N: L1 + L2"]
        end
        CP["ClientPicker"]
        CH["ConHashMap (hash ring)"]
    end

    subgraph Discovery["etcd Cluster"]
        ETCD["Service Registry<br/>/services/{svcName}/{addr}"]
    end

    subgraph Peer["Peer Node"]
        SRV["gRPC Server"]
        PG["Group (peer)"]
        HEALTH["Health Service"]
        REG["Lease Registration"]
    end

    APP -->|"Get(key)"| G
    G -->|"1. local hit?"| CACHE
    CACHE --> LRU
    LRU --> Buckets
    G -->|"2. miss: singleflight"| SF
    SF -->|"3. PickPeer"| CP
    CP --> CH
    CP -->|"watch prefix"| ETCD
    SRV -->|"register lease"| ETCD
    REG -->|"keepalive"| ETCD
    CP -->|"4. gRPC Get"| SRV
    SRV --> PG
    SRV --> HEALTH
    G -->|"fallback: Getter"| APP
