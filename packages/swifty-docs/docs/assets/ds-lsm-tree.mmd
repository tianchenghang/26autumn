graph TB
    subgraph "写入路径"
        W[Write Request] --> WAL["WAL<br/>(顺序追加写)"]
        WAL --> MT["MemTable<br/>(跳表, 内存)"]
    end

    MT -->|"flush (达到阈值)"| IMM["Immutable MemTable"]
    IMM -->|"flush to disk"| L0

    subgraph "磁盘层 (SSTable)"
        L0["L0: SSTable 集合<br/>(key 范围可重叠)"]
        L1["L1: SSTable 集合<br/>(key 范围不重叠)"]
        L2["L2: SSTable 集合<br/>(key 范围不重叠)"]
        LN["Ln: ..."]
        L0 -->|"Compaction"| L1
        L1 -->|"Compaction"| L2
        L2 -->|"Compaction"| LN
    end

    subgraph "读取路径"
        R[Read Request] --> MT
        MT -->|"miss"| L0
        L0 -->|"miss + Bloom Filter"| L1
        L1 -->|"miss + Bloom Filter"| L2
    end

    subgraph "SSTable 内部结构"
        direction LR
        DB["Data Blocks<br/>(排序 KV)"] --> IB["Index Block<br/>(稀疏索引)"]
        IB --> BF["Bloom Filter"]
        BF --> FT["Footer"]
    end
