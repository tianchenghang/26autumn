{
  "name": "swifty-vscode",
  "displayName": "Swifty vscode",
  "version": "0.0.1",
  "description": "Swifty toolchain for vscode",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hangtiancheng/swifty.git",
    "directory": "swifty-vscode"
  },
  "publisher": "hangtiancheng",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "tsup",
    "code": "code --install-extension ./swifty-vscode-0.0.1.vsix",
    "code:force": "code --install-extension ./swifty-vscode-0.0.1.vsix --force",
    "lint": "tsc --noEmit",
    "package": "pnpm build && vsce package --no-dependencies",
    "watch": "tsup --watch",
    "format": "oxfmt --write ./"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@swifty.js/mvc": "workspace:^",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "oxfmt": "^0.55.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "swifty.copyViewPath",
        "title": "Swifty: Copy View Path"
      },
      {
        "command": "swifty.openInGithub",
        "title": "Swifty: Open in GitHub"
      }
    ],
    "configuration": {
      "properties": {
        "swifty.statusBar.shortcuts": {
          "default": [],
          "description": "Status bar shortcut links",
          "items": {
            "properties": {
              "name": {
                "description": "Display name for the status bar item",
                "type": "string"
              },
              "url": {
                "description": "URL to open when clicked",
                "type": "string"
              }
            },
            "required": [
              "name",
              "url"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "title": "Swifty"
    },
    "grammars": [
      {
        "injectTo": [
          "text.html.basic"
        ],
        "path": "./syntaxes/swifty-template.tmLanguage.json",
        "scopeName": "text.html.swifty-template"
      }
    ],
    "languages": [
      {
        "aliases": [
          "Swifty Template"
        ],
        "configuration": "./language-configuration.json",
        "extensions": [],
        "id": "swifty-template"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "swifty.copyViewPath",
          "group": "0_swifty",
          "when": "vs-swifty:isSwifty"
        },
        {
          "command": "swifty.openInGithub",
          "group": "0_swifty"
        }
      ],
      "explorer/context": [
        {
          "command": "swifty.copyViewPath",
          "group": "0_swifty",
          "when": "vs-swifty:isSwifty"
        },
        {
          "command": "swifty.openInGithub",
          "group": "0_swifty"
        }
      ]
    }
  },
  "activationEvents": [
    "workspaceContains:**/package.json"
  ],
  "engines": {
    "vscode": "^1.120.0"
  }
}
